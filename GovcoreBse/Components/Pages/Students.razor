@page "/students"
@inherits BasePage
@using GovcoreBse.Middlewares;
@using GovcoreBse.Components.Layout
@using Microsoft.Extensions.Options
@using Soenneker.Blazor.FilePond
@using Soenneker.Blazor.FilePond.Dtos
@using Soenneker.Blazor.FilePond.Options
@using Soenneker.Blazor.FilePond.Enums
@using Soenneker.Utils.Random


@inject ExampleJsInterop InterJs
@inject ILogger<Students> Itlog
@inject IMediator Commander
@inject IOptions<PathSetting> Settings
@rendermode InteractiveServer


<AuthorizeView Context="authContext">
    <Authorized>
        <LayoutView Layout="typeof(HxHLayout)">
            <PageTitle>Students</PageTitle>
            <h1>Students</h1>
            <QuickGrid Items="@students" Pagination="@pagination">
                <PropertyColumn Property="@(_ => _.Id)" Sortable="true" />
                <TemplateColumn Title="Name" SortBy="@sortByName">
                    <div class="flex items-center">
                        <nobr>
                            <strong>@context.FirstName @context.LastName</strong>
                        </nobr>
                    </div>
                </TemplateColumn>
                <PropertyColumn Property="@(_ => _.School)" Sortable="true" />
            </QuickGrid>

            <Paginator State="@pagination" />

            <a href="#" @onclick="OnCallInterJs" @onclick:preventDefault="true">Click Me (Example to inject JavaScript to invoke)</a>
            <div class="row g-3">
                <div class="col-12">
                    <FilePond @ref="FilePondObj" Options="_options" OnInit="OnInit" UrlModel="_model" Urls="_urls" ></FilePond>
                </div>
                <div class="col-6">
                    <HxButton Text="Add Files"
                              Color="ThemeColor.Primary"
                              OnClick="AddFiles" />
                    <HxButton Text="Add Limbo File"
                              Color="ThemeColor.Secondary"
                              OnClick="AddLimboFile" />
                </div>
                
            </div>

        </LayoutView>
    </Authorized>
    <NotAuthorized>
        <LayoutView Layout="typeof(HxHLayout)">
            <PageTitle>Not Authorized</PageTitle>
            <h1>Not Authorized</h1>
            <p>You are not authorized to view this Students page.</p>
        </LayoutView>
    </NotAuthorized>
</AuthorizeView>







@code {
    protected List<string> ResultUrls { get; set; }
    private FilePond? FilePondObj { get; set; }
    private  FilePondOptions _options = new()
        {
            EnabledPlugins = [FilePondPluginType.ImagePreview, FilePondPluginType.MediaPreview, FilePondPluginType.PdfPreview, FilePondPluginType.GetFile],
            MaxFileSize = 100_000_000,
            UseCdn = false,
            AllowPdfPreview = true,
            PdfPreviewHeight = 200,


        };

    IQueryable<Student> students = Student.GetStudents();
    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };

    GridSort<Student> sortByName = GridSort<Student>
    .ByAscending(_ => _.FirstName).ThenAscending(_ => _.LastName);

    private FN.IUrlModel? _model;
    private string[] _urls = [];


    private async Task OnCallInterJs() => await InterJs.Prompt("Please Give Student Name?");

    private void OnInit()
    {
        Itlog.LogInformation("OnInit fired");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Itlog.LogInformation("OnAfterRenderAsync firstRender fired");
            var result  = await Commander.QueryAsync(new GetFilesAsUrlQuery(0, "G"));
            if(!result.IsError)
            {
                _model = result.Value.Key;
                _urls = result.Value.Value;
                ResultUrls = _urls.ToList();
                _options.UploadUrl = Settings.Value.FileUpload;
                _options.RemoveUrl = Settings.Value.FileRemove;
                StateHasChanged();
            }

        }
    }

    public override async ValueTask<FN.IFilePondLoadRequest?> OnFilePondRemoveFile(FN.IFilePondLoadRequest? request = null, CancellationToken cancellationToken = default)
    {
        CancellationToken linked = CancellationToken.Link(cancellationToken, out CancellationTokenSource? cts);

        using (cts)
        {
            request.InUrls = ResultUrls.ToArray();
            request.OutUrls = ResultUrls.ToArray();
            var result = await base.OnFilePondRemoveFile(request, cancellationToken);
            if (result != null)
            {
                ResultUrls = result.OutUrls.ToList();
            }

            
            return result;
        }
    }

    public override async ValueTask<FN.IFilePondLoadRequest?> OnFilePondLoadFile(FN.IFilePondLoadRequest? request=null, CancellationToken cancellationToken = default)
    {
        CancellationToken linked = CancellationToken.Link(cancellationToken, out CancellationTokenSource? cts);

        using(cts)
        {
            request.InUrls = ResultUrls.ToArray();
            request.OutUrls = ResultUrls.ToArray();
            
            var result = await base.OnFilePondLoadFile(request, cancellationToken);
            if(result!=null)
            {
                ResultUrls = result.OutUrls.ToList();
            }
            

            return result;
        }


    }
    private static string GetRandomImageUri()
    {
        int fileHeight = RandomUtil.Next(200, 500);
        int fileWidth = RandomUtil.Next(200, 500);

        return $"https://picsum.photos/{fileHeight}/{fileWidth}";
    }

    private async Task AddFiles()
    {
        await FilePondObj!.AddFiles([
            GetRandomImageUri(),
            GetRandomImageUri()
        ]);
    }

    private async Task AddLimboFile()
    {
        await FilePondObj!.AddLimboFile("test-limbo-file.txt", new FilePondAddFileOptions() { ShowFileSize = false, MimeType = "text/plain" });
        await FilePondObj.SetAllFilesSuccessWhenReady();
    }
}
